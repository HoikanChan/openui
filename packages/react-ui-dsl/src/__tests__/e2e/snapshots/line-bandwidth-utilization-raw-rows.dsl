root = VLayout([title, chart, statsTitle, statsTable])
title = Text("Bandwidth Utilization Time Trend by Device Interface", "large")
chart = LineChart(labels, series, "smooth", "Time", "Peak Bandwidth Utilization (%)")
labels = ["2024-06-01 00:00", "2024-06-01 01:00"]
series = [ne01Series, ne02Series]
ne01Series = Series("NE-01-Core-Switch GigabitEthernet0/0/1", [45.7, 52.3])
ne02Series = Series("NE-02-Access-Router Ethernet1/1", [18.2, 22.5])
statsTitle = Text("Traffic Statistics Summary", "large")
statsTable = Table([deviceCol, interfaceCol, indicatorCol, maxCol, minCol, avgCol, lastCol], data.statistics)
deviceCol = Col("Device", "deviceName")
interfaceCol = Col("Interface", "showName")
indicatorCol = Col("Indicator", "indicatorName")
maxCol = Col("Max", "max", {cell: @Render("v", @FormatNumber(v, "0.00"))})
minCol = Col("Min", "min", {cell: @Render("v", @FormatNumber(v, "0.00"))})
avgCol = Col("Avg", "avg", {cell: @Render("v", @FormatNumber(v, "0.00"))})
lastCol = Col("Last", "last", {cell: @Render("v", @FormatNumber(v, "0.00"))})