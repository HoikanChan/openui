root = VLayout([header, trendChart, statsSection])
header = Text("Bandwidth Utilization Time Trend", "large")
trendChart = LineChart(timeLabels, [ne01Series, ne02Series], "smooth", "Time", "Peak Bandwidth Utilization (%)")
timeLabels = ["2024-06-01 00:00", "2024-06-01 01:00"]
ne01Series = Series("NE-01-Core-Switch GigabitEthernet0/0/1", [45.7, 52.3])
ne02Series = Series("NE-02-Access-Router Ethernet1/1", [18.2, 22.5])
statsSection = VLayout([statsTitle, statsTable], "m")
statsTitle = Text("Traffic Statistics Summary", "large")
statsTable = Table([deviceCol, interfaceCol, maxCol, minCol, avgCol, lastCol], data.statistics)
deviceCol = Col("Device", "deviceName")
interfaceCol = Col("Interface", "showName")
maxCol = Col("Max Traffic (bps)", "max")
minCol = Col("Min Traffic (bps)", "min")
avgCol = Col("Avg Traffic (bps)", "avg")
lastCol = Col("Last Traffic (bps)", "last")