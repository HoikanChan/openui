root = HLayout([leftPanel, rightPanel], "l")
leftPanel = Card([leftHeader, leftContent], "card", "column", "m")
leftHeader = CardHeader("Left Panel", "This is the left side")
leftContent = VLayout([leftText, leftButton], "m")
leftText = Text("Content for the left panel goes here. You can add any components inside.")
leftButton = Button("Left Action", "primary")
rightPanel = Card([rightHeader, rightContent], "card", "column", "m")
rightHeader = CardHeader("Right Panel", "This is the right side")
rightContent = VLayout([rightText, rightButton], "m")
rightText = Text("Content for the right panel goes here. This side could have different widgets.")
rightButton = Button("Right Action", "default")